# Oracle (or any always-on VM) deploy env. Copy to .env and fill in. Most values copy straight from
# your Render dashboard env vars. DATABASE_URL is the SAME Neon URL, so there is no data migration.

# ---- required ----
DATABASE_URL=postgresql://USER:PASS@HOST/db?sslmode=require   # same Neon URL as Render
SECRET_KEY=replace-with-a-long-random-string                 # session signing (keep stable)
BASE_URL=https://your-host                                   # public URL (used in email/magic links)
SITE_ADDRESS=your-host                                       # Caddy hostname, NO https:// (domain or <IP>.sslip.io)
DATA_DIR=/data

# ---- scheduler: Oracle is always-on, so use the built-in scheduler (no external cron needed) ----
ENABLE_SCHEDULER=1
RUN_TZ=Asia/Kolkata
RUN_HOURS=9,15,21

# ---- unleash memory (24GB host): full Greenhouse JDs inline + more concurrency ----
ATS_FULL_CONTENT=1
ATS_WORKERS=40
ATS_DESC_CHARS=4000
POOL_CAP=800
ATS_CAP=500

# ---- matching ----
MAX_MATCHES_PER_RUN=10
MIN_SCORE=3

# ---- semantic matching (you already set these on Render) ----
SEMANTIC_MATCHING=1
GEMINI_API_KEY=

# ---- LLM (Groq) for rerank + tailoring ----
LLM_PROVIDER=groq
LLM_API_KEY=

# ---- job sources (optional; you already have these) ----
JSEARCH_RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---- Google sign-in: AFTER deploy add https://BASE_URL/auth/google/callback to the Authorized
#      redirect URIs in Google Cloud Console, or sign-in breaks ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- email (Brevo HTTP API = the proven path; copy both from Render) ----
# BREVO_API_KEY must be the v3 API key (starts xkeysib-), and EMAIL_FROM must be a Brevo-verified
# sender. (On Oracle plain SMTP would also work since it isn't blocked like Render, but reuse Brevo.)
BREVO_API_KEY=
EMAIL_FROM=
# optional SMTP fallback (only if not using Brevo):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ---- telegram bot (optional) ----
TELEGRAM_BOT_TOKEN=
