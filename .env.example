# Copy to .env and fill in. All optional except the Telegram bot token (for notifications).

# Telegram bot (create via @BotFather). Required to send job alerts.
TELEGRAM_BOT_TOKEN=

# Adzuna (free tier, covers India + global). Get keys at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch via RapidAPI (aggregates Google-for-Jobs incl. LinkedIn/Indeed listings).
# Free tier at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_RAPIDAPI_KEY=

# Optional extra job sources (all OFF until set; the app runs fine without them).
# MUSE_API_KEY: optional, raises The Muse rate limit (The Muse already works keyless).
MUSE_API_KEY=
# THEIRSTACK_API_KEY: the only aggregator that legitimately includes Naukri (~200 jobs/mo free tier).
THEIRSTACK_API_KEY=
# JOOBLE_API_KEY: free licensed aggregator with India coverage (jooble.org/api/about).
JOOBLE_API_KEY=

# How many top matches to send per user per run.
MAX_MATCHES_PER_RUN=8

# Minimum match score (number of profile keywords a job must hit) to be sent.
MIN_SCORE=3

# V2: LLM resume tailoring (optional). Leave LLM_API_KEY empty to disable.
# Free options: groq (fast, free) or gemini (generous free tier). openai/anthropic are paid.
# LLM_PROVIDER: openai | groq | gemini | anthropic
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_MODEL=

